<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Controller.menuController.DSSP_DichVuController">

    <!-- Thanh trên cùng -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #f5f5f5;">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
            <Label text="🔍 Tìm kiếm:" />
            <TextField fx:id="txtTimKiem" promptText="Nhập tên sản phẩm..." />
            <Button text="Tìm" onAction="#timKiemSanPham" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Thêm" onAction="#themSanPham" />
            <Button text="Sửa" onAction="#suaSanPham" />
            <Button text="Xóa" onAction="#xoaSanPham" />
        </HBox>
    </top>

    <!-- Bảng danh sách sản phẩm -->
    <center>
        <TableView fx:id="tableSanPham" prefHeight="400" prefWidth="800" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colMaSP" text="Mã SP" prefWidth="80" />
                <TableColumn fx:id="colTenSP" text="Tên sản phẩm" prefWidth="200" />
                <TableColumn fx:id="colLoai" text="Loại" prefWidth="150" />
                <TableColumn fx:id="colGia" text="Giá" prefWidth="100" />
                <TableColumn fx:id="colSoLuong" text="Số lượng" prefWidth="100" />
            </columns>
        </TableView>
    </center>

    <!-- Thanh dưới cùng -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
            <Label text="Tổng số sản phẩm:" />
            <Label fx:id="lblTongSP" text="0" style="-fx-font-weight: bold;" />
        </HBox>
    </bottom>

</BorderPane>
