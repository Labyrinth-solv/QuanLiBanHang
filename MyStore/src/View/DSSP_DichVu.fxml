<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Controller.menuController.DSSP_DichVuController">

    <!-- Thanh trên cùng -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #f5f5f5;">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
            <Label text="🔍 Tìm kiếm:" />
            <TextField fx:id="txtTimKiem" promptText="Nhập tên sản phẩm..." />
            <Button text="Tìm" onAction="#timKiemSanPham" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Thêm" onAction="#themSanPham" />
            <Button text="Sửa" onAction="#suaSanPham" />
            <Button text="Xóa" onAction="#xoaSanPham" />
        </HBox>
    </top>

    <!-- Bảng danh sách sản phẩm -->
    <center>
        <VBox spacing="5">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- TableView -->
            <TableView fx:id="tableSanPham" prefHeight="400" prefWidth="800">
                <columns>
                    <TableColumn fx:id="colId" text="Mã SP" prefWidth="80" />
                    <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="200" />
                    <TableColumn fx:id="colCategoryId" text="Loại" prefWidth="150" />
                    <TableColumn fx:id="colSupplierId" text="Giá" prefWidth="100" />
                    <TableColumn fx:id="colUnit" text="Số lượng" prefWidth="100" />
                </columns>
            </TableView>

            <!-- TextField nằm ngay dưới TableView -->
            <VBox spacing="10">
                <HBox spacing="10">
                    <Label text="Mã SP:" />
                    <TextField fx:id="txtId" />
                    <Label text="Nhà cung cấp:" />
                    <TextField fx:id="txtSupplierId" />
                </HBox>
                <HBox spacing="10">
                    <Label text="Loại:" />
                    <TextField fx:id="txtCategoryId" />
                    <Label text="Tên SP:" />
                    <TextField fx:id="txtName" />
                    <Label text="Đơn vị:" />
                    <TextField fx:id="txtUnit" />
                </HBox>
            </VBox>
        </VBox>
    </center>




    <!-- Thanh dưới cùng -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
            <Label text="Tổng số sản phẩm:" />
            <Label fx:id="lblTongSP" text="0" style="-fx-font-weight: bold;" />
        </HBox>
    </bottom>

</BorderPane>
