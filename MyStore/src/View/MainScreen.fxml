<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="700.0" maxWidth="1350.0" prefHeight="700.0" prefWidth="1350.0"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.MainScreenController">

    <center>
        <TabPane fx:id="tab" prefHeight="640.0" prefWidth="1015.0" tabClosingPolicy="ALL_TABS" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="10.0" left="3.0" right="10.0" top="10.0" />
            </BorderPane.margin>
        </TabPane>
    </center>

    <!-- Cột bên trái -->
    <left>
        <HBox prefHeight="660.0" prefWidth="295.0" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" top="15.0"/>
            </padding>
            <VBox alignment="TOP_CENTER" prefHeight="630.0" prefWidth="270.0" spacing="3.0">
                <HBox.margin>
                    <Insets left="5.0"/>
                </HBox.margin>

                <!-- Dịch vụ -->
                <TitledPane collapsible="false" prefHeight="114.0" prefWidth="250.0" text="Dịch vụ">
                    <VBox spacing="5.0">
                        <padding>
                            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
                        </padding>
                        <Button fx:id="btnDanhSachSanPham_DichVu" prefHeight="35.0" prefWidth="170.0"
                                style="-fx-background-color: transparent;" text="Danh sách sản phẩm"/>
                        <Button fx:id="btnHoaDon_DichVu" prefHeight="35.0" prefWidth="170.0"
                                style="-fx-background-color: transparent;" text="Thanh toán"/>
                    </VBox>
                </TitledPane>
                <!-- Nhân viên -->
                <TitledPane collapsible="false" prefHeight="114.0" prefWidth="250.0" text="Nhân viên">
                    <VBox spacing="5.0">
                        <padding>
                            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
                        </padding>
                        <Button fx:id="btnDanhSach_NhanVien" prefHeight="35.0" prefWidth="170.0"
                                style="-fx-background-color: transparent;" text="Danh sách nhân viên"/>
                        <Button fx:id="btnThemNhanVien" prefHeight="35.0" prefWidth="170.0"
                                style="-fx-background-color: transparent;" text="Thêm nhân viên"/>
                    </VBox>
                </TitledPane>

                <!-- Báo cáo thu chi -->
                <TitledPane collapsible="false" prefHeight="114.0" prefWidth="250.0" text="Báo cáo thu chi">
                    <VBox spacing="5.0">
                        <padding>
                            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
                        </padding>
                        <Button fx:id="btnBaoCaoDoanhThu" prefHeight="35.0" prefWidth="170.0"
                                style="-fx-background-color: transparent;" text="Doanh thu"/>
                    </VBox>
                </TitledPane>

            </VBox>
        </HBox>
    </left>

    <!-- Cột bên phải (Tìm kiếm) -->
    <right>
        <VBox alignment="TOP_CENTER" spacing="10.0" prefWidth="270.0" prefHeight="630.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="10.0"/>
            </padding>
            <TitledPane collapsible="false" prefHeight="114.0" prefWidth="250.0" text="Tìm kiếm">
                <VBox spacing="5.0">
                    <padding>
                        <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
                    </padding>
                    <Button fx:id="btnDanhSachHoaDon" prefHeight="35.0" prefWidth="170.0"
                            style="-fx-background-color: transparent;" text="Danh sách hóa đơn"/>

                </VBox>
            </TitledPane>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER_RIGHT" prefHeight="30.0" prefWidth="1350.0"
              spacing="15.0" style="-fx-background-color: #00CCFF;">
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </padding>
            <Text text="Ngày:"/>
            <Text fx:id="txtNgay" fill="RED" text="26/12/1997"/>
            <Text text="Nhân viên:"/>
            <Text fx:id="txtTenNhanVien" fill="RED" text="Phan Thế Anh"/>
        </HBox>
    </bottom>

</BorderPane>
